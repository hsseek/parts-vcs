# Copy this to .env and fill in your values
# Get API keys from: https://cad.onshape.com/user/settings -> API Keys

ONSHAPE_ACCESS_KEY=your_access_key_here
ONSHAPE_SECRET_KEY=your_secret_key_here
ONSHAPE_BASE_URL=https://cad.onshape.com

# Admin authentication
# ADMIN_PASSPHRASE: the passphrase admins type to log in
# ADMIN_SESSION_SECRET: any long random string — rotate this to invalidate all sessions
ADMIN_PASSPHRASE=change_me
ADMIN_SESSION_SECRET=change_me_to_a_long_random_string

# Email — used to notify the admin when a user requests Onshape access
# ADMIN_EMAIL: address that receives access-request notifications
# SMTP_HOST / SMTP_PORT / SMTP_USER / SMTP_PASSWORD: outgoing SMTP credentials
#   e.g. Gmail: host=smtp.gmail.com port=587, use an App Password for SMTP_PASSWORD
ADMIN_EMAIL=admin@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
