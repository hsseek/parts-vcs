# Copy this to .env and fill in your values
# Get API keys from: https://cad.onshape.com/user/settings -> API Keys

ONSHAPE_ACCESS_KEY=your_access_key_here
ONSHAPE_SECRET_KEY=your_secret_key_here
ONSHAPE_BASE_URL=https://cad.onshape.com

# Admin authentication
# ADMIN_PASSPHRASE: the passphrase admins type to log in
# ADMIN_SESSION_SECRET: any long random string — rotate this to invalidate all sessions
ADMIN_PASSPHRASE=change_me
ADMIN_SESSION_SECRET=change_me_to_a_long_random_string
